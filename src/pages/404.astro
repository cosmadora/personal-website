---
import BaseHead from "../components/BaseHead.astro";
---

<BaseHead
  title="404 - Adoras Website <3"
  description="Adoras personal website, cv and portfolio 🌷"
  noindex={false}
/>
  <body>
    <div class="content">
      <img
        src="data:image/webp;base64,"
        height="300"
      />
      <div class="center">
        <h1>Oops, looks like someone ate the page!?</h1>
        <p>Unfortunately the page you tried to access doesn't exist.</p>
        <p>
        You can try to <a href="javascript:window.history.back();">go back</a> 
        &nbsp;or&nbsp;
        <a href="/">go home ;)</a></p>
      </div>
    </div>
  </body>

<style scoped>
  html,
  body {
    height: 100%;
  }

  body {
    padding: 0;
    border: 0;
    vertical-align: baseline;
    font-family: Tahoma, sans-serif;
    font-size: 1em;
    line-height: 1.4;
    margin: 1em auto;
    max-width: 45em;
    background: #212121;
    color: #fff;
    font-weight: 200;
  }

  a {
    text-decoration: none;
    color: #1492ff;
  }

  h1,
  h2,
  h3,
  p {
    font-weight: 200;
    text-align: center;
    margin-bottom: 0;
  }

  p {
    margin-top: 0;
  }

  img {
    border-radius: 50%;
    display: block;
    margin-left: auto;
    margin-right: auto;
  }

  center {
    display: block;
    margin-left: auto;
    margin-right: auto;
  }

  .content {
    height: 100%;
    width: 100%;
  }
</style>
